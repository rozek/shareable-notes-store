{
  "name": "@rozek/sds-command",
  "description": "CLI tool for shareable-data-store — interactive REPL, one-shot and batch commands",
  "version": "0.0.12",
  "keywords": [
    "crdt",
    "cli",
    "repl",
    "shareable-data-store"
  ],
  "author": "Andreas Rozek",
  "homepage": "https://github.com/rozek/shareable-data-store#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozek/shareable-data-store.git",
    "directory": "packages/sds-command"
  },
  "bugs": {
    "url": "https://github.com/rozek/shareable-data-store/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "type": "module",
  "main": "./dist/sds-command.js",
  "module": "./dist/sds-command.js",
  "types": "./dist/sds-command.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sds-command.js",
      "types": "./dist/sds-command.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rozek/sds-core": "workspace:*",
    "@rozek/sds-network-websocket": "workspace:*",
    "@rozek/sds-persistence-node": "workspace:*",
    "@rozek/sds-sync-engine": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@rozek/sds-core-jj": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
