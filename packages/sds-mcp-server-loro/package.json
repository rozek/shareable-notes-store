    }
  },
  "bin": {
    "sds-mcp-server-loro": "./dist/sds-mcp-server-loro.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev":       "vite build --watch",
    "build":     "vite build",
    "test":      "vitest",
    "test:run":  "vitest run",
