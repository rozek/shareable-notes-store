{
  "name": "@rozek/sds-mcp-server",
  "description": "MCP server for shareable-data-store — exposes all store operations as MCP tools",
  "version": "0.0.12",
  "keywords": [
    "crdt",
    "mcp",
    "model-context-protocol",
    "shareable-data-store"
  ],
  "author": "Andreas Rozek",
  "homepage": "https://github.com/rozek/shareable-data-store#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozek/shareable-data-store.git",
    "directory": "packages/sds-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/rozek/shareable-data-store/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "type": "module",
  "main": "./dist/sds-mcp-server.js",
  "module": "./dist/sds-mcp-server.js",
  "types": "./dist/sds-mcp-server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sds-mcp-server.js",
      "types": "./dist/sds-mcp-server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev":       "vite build --watch",
    "build":     "vite build",
    "test":      "vitest",
    "test:run":  "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@rozek/sds-core": "workspace:*",
    "@rozek/sds-network-websocket": "workspace:*",
    "@rozek/sds-persistence-node": "workspace:*",
    "@rozek/sds-sync-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node":     "^22.0.0",
    "typescript":      "^5.7.2",
    "vite":            "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest":          "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
