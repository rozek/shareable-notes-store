{
  "name": "@rozek/sds-websocket-server",
  "description": "WebSocket server for shareable-data-store (Hono, JWT auth, multi-store)",
  "version": "0.0.8",
  "author": "Andreas Rozek",
  "homepage": "https://github.com/rozek/shareable-data-store#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozek/shareable-data-store.git",
    "directory": "packages/websocket-server"
  },
  "bugs": {
    "url": "https://github.com/rozek/shareable-data-store/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/sds-websocket-server.js",
  "module": "./dist/sds-websocket-server.js",
  "types": "./dist/sds-websocket-server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sds-websocket-server.js",
      "types": "./dist/sds-websocket-server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "sds-server": "./dist/sds-websocket-server.js"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "start": "node dist/sds-websocket-server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@hono/node-ws": "^1.0.0",
    "hono": "^4.0.0",
    "jose": "^5.0.0"
  },
  "peerDependencies": {
    "@rozek/sds-persistence-node": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@rozek/sds-persistence-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rozek/sds-persistence-node": "workspace:*",
    "@types/node": "^25.3.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.5"
  }
}
